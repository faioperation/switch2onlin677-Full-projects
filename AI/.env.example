# ═══════════════════════════════════════════════════════════════════════════════
# AI SERVICE — Environment Variables
# DhifafBot FastAPI AI Engine (FastAPI + PostgreSQL + Redis + OpenAI)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Required. Your OpenAI API key. Must have access to gpt-4o and gpt-4o-mini.
# Used by: ai/orchestrator.py, services/embedding.py
OPENAI_API_KEY=sk-...

# ─── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string with pgvector extension installed.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Used by: core/database.py, all SQLAlchemy models, Alembic migrations
DATABASE_URL=postgresql://postgres:admin123@postgres:5432/simple_test_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Optional. If not set, caching is automatically disabled (graceful degradation).
# Format: redis://:PASSWORD@HOST:PORT/DB_INDEX
# Used by: services/cache_service.py
REDIS_URL=redis://:admin123@redis:6379/0

# ─── SAP Integration ───────────────────────────────────────────────────────────
# Required for price/stock sync. URL must point to SAP's OData /getItems endpoint.
# SAP sync runs twice daily at 06:00 and 18:00 Asia/Baghdad.
# Used by: services/sync.py
SAP_API_URL=https://your-sap-server/api/getItems

# ─── Leads API ─────────────────────────────────────────────────────────────────
# Optional. URL of the Django backend for lead registration.
# Used by: services/lead_service.py
LEADS_API_URL=http://backend:8000/api/v1/leads/

# ─── GPT Tuning ────────────────────────────────────────────────────────────────
# Optional. Override default GPT behaviour.
# Used by: ai/orchestrator.py
GPT_TEMPERATURE=0.7
GPT_MAX_TOKENS=1000
GPT_MAX_TOOL_LOOPS=6
GPT_MAX_RETRIES=3

# ─── Circuit Breaker ───────────────────────────────────────────────────────────
# Optional. Tune how quickly the OpenAI circuit breaker trips.
# Used by: core/circuit_breaker.py
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=60
CB_SUCCESS_THRESHOLD=2

# ─── Cache TTLs (seconds) ──────────────────────────────────────────────────────
# Optional. Control Redis cache expiry windows.
# Used by: services/cache_service.py
CACHE_TTL_PRODUCT_LIST=1800
CACHE_TTL_PRODUCT_DETAIL=3600
CACHE_TTL_AVAILABILITY=900
CACHE_TTL_HANDOFF_STATE=600

# ─── Recommendation Scorer ─────────────────────────────────────────────────────
# Optional. Set to "hybrid_ai" when ≥50% of products have embeddings.
# Default is rule-based scoring. Used by: services/ai_recommendation.py
RECOMMENDATION_SCORER=rule_based

# Score weights for the hybrid scoring formula:
SCORE_W_SEMANTIC=0.40
SCORE_W_EDITORIAL=0.22
SCORE_W_POPULARITY=0.15
SCORE_W_STOCK=0.13
SCORE_W_FRESHNESS=0.10
SCORE_ALPHA=0.55

# ─── Multi-worker Scheduler Guard ─────────────────────────────────────────────
# Set to 0 in the first Gunicorn worker to enable the scheduler.
# Set automatically via Gunicorn post_fork hook in production.
# Used by: main.py
APP_WORKER_ID=0
