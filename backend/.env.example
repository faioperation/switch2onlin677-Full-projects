# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND SERVICE — Environment Variables
# Django 6 REST API + JWT Auth + Meta Webhooks + AI Proxy
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ─── Django Core ───────────────────────────────────────────────────────────────
# Required. Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-50-character-django-secret-key-here

# Required. Set to False in production.
DEBUG=False

# Required. Comma-separated list of allowed hostnames.
# Example: test1.fireai.agency,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Required. Comma-separated list of trusted CSRF origins (include scheme).
# Example: https://test1.fireai.agency
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ─── AI Service Integration ────────────────────────────────────────────────────
# Required. Internal URL of the AI (FastAPI) service.
# In Docker Compose: http://ai:8000
# Used by: ai_proxy/views.py, conversation/bot_service.py
AI_BOT_BASE_URL=http://ai:8000

# ─── Leads API ─────────────────────────────────────────────────────────────────
# Optional. API key for lead creation (set if your leads endpoint requires auth).
LEADS_API_KEY=

# ─── Email / SMTP ──────────────────────────────────────────────────────────────
# Required for password-reset OTP emails.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password

# ─── Meta / Facebook / Instagram / WhatsApp Webhooks ──────────────────────────
# Required for social media webhook verification.
META_VERIFY_TOKEN=your_custom_webhook_verification_token

# Facebook Messenger Page Access Token
META_FB_PAGE_ACCESS_TOKEN=

# Instagram Business Access Token (starts with IGA...)
META_IG_PAGE_ACCESS_TOKEN=

# WhatsApp Cloud API
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=

# Legacy Meta tokens (may be required for certain Graph API calls)
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ─── SSL / Proxy ───────────────────────────────────────────────────────────────
# Optional. Set if behind a reverse proxy that terminates SSL.
# Format: HTTP_X_FORWARDED_PROTO,https
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
